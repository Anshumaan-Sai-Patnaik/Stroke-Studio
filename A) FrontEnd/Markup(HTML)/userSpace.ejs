<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>StrokeStudio — My Collection</title>
    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>
    <link rel="stylesheet" href="../Style(CSS)/userSpace.css">
</head>
<body>
    <div class="toast" id="toast">
        <i class="fa-solid fa-check"></i>
        <span id="toastMsg">Done</span>
    </div>

    <div class="acct-backdrop" id="signOutModal" style="align-items:center; padding:1.5rem;">
        <div class="acct-modal" style="max-height:none; overflow-y:visible; align-self:auto;">
            <div class="acct-modal-header">
                <div class="acct-modal-icon"><i class="fa-solid fa-arrow-right-from-bracket"></i></div>
                <div class="acct-modal-title-wrap">
                    <div class="acct-modal-eyebrow">Session</div>
                    <div class="acct-modal-title">Sign Out</div>
                </div>
                <button class="acct-close" data-close="signOutModal"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="signout-body">
                <p>You're signed in as <strong><%= userInfo.username %></strong>.</p>
                <p style="margin-top:0.6rem;">Signing out will end your session. Your cart and wishlist are saved — they'll be right here when you return.</p>
            </div>
            <div class="acct-modal-footer" style="position:static;">
                <button class="acct-btn acct-btn-ghost" data-close="signOutModal">Stay Signed In</button>
                <a class="acct-btn acct-btn-gold" href="http://localhost:3000/user/signout" style="text-decoration:none;">
                    <i class="fa-solid fa-arrow-right-from-bracket"></i> Yes, Sign Out
                </a>
            </div>
        </div>
    </div>

    <div class="acct-backdrop" id="editProfileModal">
        <div class="acct-modal">
            <div class="acct-modal-header">
                <div class="acct-modal-icon"><i class="fa-regular fa-pen-to-square"></i></div>
                <div class="acct-modal-title-wrap">
                    <div class="acct-modal-eyebrow">Account Settings</div>
                    <div class="acct-modal-title">Edit Profile</div>
                </div>
                <button class="acct-close" data-close="editProfileModal"><i class="fa-solid fa-xmark"></i></button>
            </div>

            <div class="acct-modal-body">
                <div class="acct-feedback" id="editFeedback"></div>
                <div class="acct-avatar-row">
                    <div class="acct-avatar-preview" id="editAvatarPreview">
                        <img src="/<%= userInfo.image.replace('Uploads/', '') %>.jpg">
                    </div>
                    <div class="acct-avatar-meta">
                        <div class="acct-avatar-name">Profile photo</div>
                        <label class="acct-upload-btn" for="avatarFileInput">
                            <i class="fa-solid fa-arrow-up-from-bracket"></i> Upload New
                        </label>
                        <input type="file" id="avatarFileInput" accept="image/*" style="display:none;"/>
                    </div>
                </div>
                <div class="ep-info-grid">
                    <div class="ep-info-row">
                        <span class="ep-info-label">User ID</span>
                        <span class="ep-info-value"><%= userInfo.userID %></span>
                    </div>
                    <div class="ep-info-row">
                        <span class="ep-info-label">Email</span>
                        <span class="ep-info-value"><%= userInfo.emailID %></span>
                    </div>
                    <div class="ep-info-row ep-editable-row">
                        <span class="ep-info-label">Username</span>
                        <input class="ep-inline-input" type="text" name="newUsername" id="editUsername" value="<%= userInfo.username %>" placeholder="Enter username" autocomplete="off"/>
                    </div>
                </div>
                <div class="acct-divider"></div>
                <div class="acct-section-label">Change Password</div>
                <div class="acct-field">
                    <label class="acct-label" for="editCurrentPw">Current Password</label>
                    <div class="pw-input-wrap">
                        <input class="acct-input" type="password" id="editCurrentPw" placeholder="Enter your current password"/>
                        <button class="pw-verify-btn" id="verifyCurrentPwBtn" type="button">
                            <i class="fa-solid fa-arrow-right"></i>
                        </button>
                    </div>
                    <div class="acct-input-hint" id="currentPwHint"></div>
                </div>
                <div class="pw-new-section locked" id="pwNewSection">
                    <div class="pw-locked-msg" id="pwLockedMsg">
                        <i class="fa-solid fa-lock"></i>
                        Verify your current password above to unlock
                    </div>
                    <div class="pw-new-fields" id="pwNewFields">
                        <div class="acct-field">
                            <label class="acct-label" for="editNewPw">New Password</label>
                            <input class="acct-input" type="password" name="newPassword" id="editNewPw" placeholder="New password" disabled/>
                        </div>
                        <div class="acct-field">
                            <label class="acct-label" for="editConfirmPw">Confirm New Password</label>
                            <input class="acct-input" type="password" id="editConfirmPw" placeholder="Confirm new password" disabled/>
                            <div class="acct-input-hint" id="pwMatchHint"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="acct-modal-footer">
                <button class="acct-btn acct-btn-ghost" id="cancelSave" data-close="editProfileModal">Cancel</button>
                <button class="acct-btn acct-btn-gold" id="saveProfileBtn">
                    <i class="fa-solid fa-check"></i> Save Changes
                </button>
            </div>
        </div>
    </div>

    <div class="acct-backdrop" id="deleteAccountModal" style="align-items:center; padding:1.5rem;">
        <div class="acct-modal danger" style="max-height:none; overflow-y:visible; align-self:auto;">
            <div class="acct-modal-header">
                <div class="acct-modal-icon"><i class="fa-solid fa-triangle-exclamation"></i></div>
                <div class="acct-modal-title-wrap">
                    <div class="acct-modal-eyebrow">Danger Zone</div>
                    <div class="acct-modal-title">Delete Account</div>
                </div>
                <button class="acct-close" data-close="deleteAccountModal"><i class="fa-solid fa-xmark"></i></button>
            </div>

            <div class="acct-modal-body">
                <div class="danger-info">
                    <p>This action is <strong>permanent and irreversible.</strong> Deleting your account will erase your profile, cart, wishlist, and all purchase history. This cannot be undone.</p>
                </div>
                <div class="danger-confirm-row">
                    <input type="checkbox" id="deleteConfirmCheck"/>
                    <label for="deleteConfirmCheck">I understand that my account and all associated data will be permanently deleted.</label>
                </div>
                <div class="acct-field">
                    <div class="danger-type-label">Type <strong><%= userInfo.username %></strong> to confirm</div>
                    <input class="acct-input" type="text" id="deleteConfirmInput" placeholder="Type your username here" autocomplete="off"/>
                </div>
            </div>
            
            <div class="acct-modal-footer">
                <button class="acct-btn acct-btn-ghost" id="cancelDelete" data-close="deleteAccountModal">Cancel</button>
                <button class="acct-btn acct-btn-danger" id="confirmDeleteBtn" disabled>
                    <i class="fa-solid fa-trash-can"></i> Delete My Account
                </button>
            </div>
        </div>
    </div>

    <div class="acct-backdrop cart-summary-modal-backdrop" id="cartSummaryModal" style="align-items:center; padding:1.5rem;">
        <div class="acct-modal" style="max-height:none; overflow-y:visible; align-self:auto; min-width: 450px; max-width: 450px;">
            <div class="acct-modal-header">
                <div class="acct-modal-icon"><i class="fa-solid fa-cart-shopping"></i></div>
                <div class="acct-modal-title-wrap">
                    <div class="acct-modal-eyebrow">Yay!</div>
                    <div class="acct-modal-title">Cart <em style="font-style:italic;color:var(--gold);">Summary</em></div>
                </div>
                <button class="acct-close" data-close="cartSummaryModal"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="acct-modal-body">
                <div class="csm-label">Total</div>
                <div class="csm-total">₹<span id="csmTotal">0</span></div>
                <div class="csm-meta"><span id="csmItemCount">0</span> <span id="csmItemLabel">items</span> in cart</div>
                <button class="csm-checkout empty" id="csmCheckoutBtn">
                    <i class="fa-solid fa-arrow-right"></i> Proceed to Checkout
                </button>
            </div>
        </div>
    </div>

    <div class="detail-backdrop" id="detailModal">
        <div class="detail-modal">
            <button class="detail-close" id="closeDetail"><i class="fa-solid fa-xmark"></i></button>

            <div class="detail-img-wrap">
                <img id="detailImg" src=""/>
                <div class="detail-img-badge" id="detailMediumBadge"></div>
            </div>

            <div class="detail-info">
                <div>
                    <div class="detail-eyebrow" id="detailStyle"></div>
                    <h2 class="detail-title" id="detailTitle"></h2>
                    <div class="detail-artist">By <span id="detailArtist"></span> &nbsp;·&nbsp; <span id="detailYear"></span></div>
                    <div class="detail-meta">
                        <div class="detail-meta-item">
                            <div class="detail-meta-label">Medium</div>
                            <div class="detail-meta-val" id="detailMetaMedium"></div>
                        </div>
                        <div class="detail-meta-item">
                            <div class="detail-meta-label">Style</div>
                            <div class="detail-meta-val" id="detailMetaStyle"></div>
                        </div>
                        <div class="detail-meta-item">
                            <div class="detail-meta-label">Dimensions</div>
                            <div class="detail-meta-val" id="detailMetaDimensions"></div>
                        </div>
                        <div class="detail-meta-item">
                            <div class="detail-meta-label">Year</div>
                            <div class="detail-meta-val" id="detailMetaYear"></div>
                        </div>
                    </div>
                    <div class="detail-price">
                        <sub>₹ </sub><span id="detailPrice"></span>
                    </div>
                </div>
                <div class="detail-actions">

                </div>
            </div>
        </div>
    </div>

    <nav>
        <a class="nav-logo" href="/home">Stroke<span>Studio</span></a>
        <div class="nav-actions">
            <span class="nav-user-name">Welcome, <strong><%= userInfo.username %></strong></span>
            <button class="nav-cart-btn" id="navCartBtn" title="View Cart">
                <i class="fa-solid fa-bag-shopping"></i>
                <span class="nav-cart-badge" id="cartBadge">0</span>
            </button>
            <a class="btn-signout" id="openSignOutNav"><i class="fa-solid fa-arrow-right-from-bracket"></i> Sign Out</a>
        </div>
        <div class="nav-actions-icons">
            <button class="nav-cart-btn" id="mobileCartToggle" title="Cart">
                <i class="fa-solid fa-bag-shopping"></i>
                <span class="nav-cart-badge" id="cartBadgeMobile">0</span>
            </button>
            <button class="nav-icon-btn" id="openSignOutMobile" title="Sign Out">
                <i class="fa-solid fa-arrow-right-from-bracket"></i>
            </button>
        </div>
    </nav>

    <div class="page-wrap">
        <aside class="sidebar">
            <div class="profile-card">
                <div class="profile-pic">
                    <div class="profile-avatar">
                        <img src="/<%= userInfo.image.replace('Uploads/', '') %>.jpg">
                    </div>
                </div>
                <div class="profile-name"><%= userInfo.username %></div>
                <div class="profile-id">ID · <%= userInfo.userID %></div>
                <div class="profile-email"><%= userInfo.emailID %></div>
                <div class="profile-actions">
                    <button class="profile-action-btn" id="openEditProfile">
                        <i class="fa-regular fa-pen-to-square"></i> Edit
                    </button>
                    <button class="profile-action-btn danger" id="openDeleteAccount">
                        <i class="fa-solid fa-trash-can"></i> Delete
                    </button>
                </div>
            </div>

            <div class="sidebar-tabs">
                <button class="stab active" data-target="panel-cart">
                    <i class="fa-solid fa-bag-shopping"></i>
                    My Cart
                    <span class="stab-count" id="sideCartCount">0</span>
                </button>
                <button class="stab" data-target="panel-wish">
                    <i class="fa-regular fa-heart"></i>
                    Wishlist
                    <span class="stab-count" id="sideWishCount">0</span>
                </button>
                <button class="stab" data-target="panel-purchased">
                    <i class="fa-solid fa-box-archive"></i>
                    Purchased
                    <span class="stab-count" id="sidePurchasedCount">0</span>
                </button>
                <button class="stab" data-target="panel-gallery">
                    <i class="fa-solid fa-palette"></i>
                    Browse All Works
                    <span class="stab-count" id="sideGalleryCount">0</span>
                </button>
            </div>

            <div class="cart-summary">
                <div class="cart-summary-label">Cart Total</div>
                <div class="cart-summary-total">₹<span id="cartTotal">0</span></div>
                <div class="cart-summary-meta"><span id="cartItemCount">0</span> <span id="cartItemLabel">items</span> selected</div>
                <button class="btn-checkout empty" id="checkoutBtn">
                    <i class="fa-solid fa-arrow-right"></i> Proceed to Checkout
                </button>
            </div>
        </aside>

        <main class="main-content">
            <div class="tab-panel active" id="panel-cart">
                <div class="panel-header">
                    <div>
                        <div class="panel-eyebrow">
                            <div class="panel-eyebrow-line"></div>
                            <span>Your Collection</span>
                        </div>
                        <h2 class="panel-title">My <em>Cart</em></h2>
                    </div>
                    <div class="panel-meta" id="cartHeaderMeta"></div>
                </div>

                <div class="painting-list" id="cartList">
                    <%
                        // cartPaintings is populated server-side from cartItems ObjectIDs
                    %>
                </div>
                <div class="empty-state" id="cartEmpty" style="display:none;">
                    <div class="empty-state-icon"><i class="fa-solid fa-bag-shopping"></i></div>
                    <h3>Your cart is empty</h3>
                    <p>Browse the full collection and add works that speak to you.</p>
                    <button class="empty-state-cta" data-target="panel-gallery">Explore Gallery</button>
                </div>
            </div>

            <div class="tab-panel" id="panel-wish">
                <div class="panel-header">
                    <div>
                        <div class="panel-eyebrow">
                            <div class="panel-eyebrow-line"></div>
                            <span>Saved for Later</span>
                        </div>
                        <h2 class="panel-title">My <em>Wishlist</em></h2>
                    </div>
                    <div class="panel-meta" id="wishHeaderMeta"></div>
                </div>

                <div class="painting-list" id="wishList">
                    <%
                        // wishList is populated server-side from wishList ObjectIDs
                    %>
                </div>
                <div class="empty-state" id="wishEmpty" style="display:none;">
                    <div class="empty-state-icon"><i class="fa-regular fa-heart"></i></div>
                    <h3>Nothing saved yet</h3>
                    <p>Heart paintings you love to revisit them here anytime.</p>
                    <button class="empty-state-cta" data-target="panel-gallery">Explore Gallery</button>
                </div>
            </div>

            <div class="tab-panel" id="panel-purchased">
                <div class="panel-header">
                    <div>
                        <div class="panel-eyebrow">
                            <div class="panel-eyebrow-line"></div>
                            <span>Order History</span>
                        </div>
                        <h2 class="panel-title">My <em>Purchases</em></h2>
                    </div>
                    <div class="panel-meta" id="purchasedHeaderMeta"></div>
                </div>

                <div class="painting-list" id="purchasedList">
                    <%
                        // purchased is populated server-side from purchased ObjectIDs
                    %>
                </div>
                <div class="empty-state" id="purchasedEmpty" style="display:none;">
                    <div class="empty-state-icon"><i class="fa-solid fa-box-archive"></i></div>
                    <h3>No purchases yet</h3>
                    <p>Once you complete a checkout, your acquired works appear here.</p>
                    <button class="empty-state-cta" data-target="panel-gallery">Start Collecting</button>
                </div>
            </div>

            <div class="tab-panel" id="panel-gallery">
                <div class="panel-header">
                    <div>
                        <div class="panel-eyebrow">
                            <div class="panel-eyebrow-line"></div>
                            <span>Full Collection</span>
                        </div>
                        <h2 class="panel-title">Browse <em>All Works</em></h2>
                    </div>
                </div>

                <div class="gallery-search-bar">
                    <div class="gsb-wrap">
                        <i class="fa-solid fa-magnifying-glass"></i>
                        <input type="text" id="gallerySearchInput" placeholder="Search by title, artist, medium or style"/>
                    </div>
                    <div class="gsb-divider"></div>
                    <button class="gsb-btn" id="gallerySearchBtn">
                        <i class="fa-solid fa-arrow-right"></i> Search
                    </button>
                </div>
                <div class="gallery-result-meta" id="galleryResultMeta"><%=allWorks.length%> Works in Collection</div>

                <div class="gallery-wrapper">
                    <div class="masonry-grid" id="masonryGrid">
                        <% for(let i = 0; i < allWorks.length; i++) { %>
                        <div
                            class="gallery-item"
                            data-index="<%= i %>"
                            data-id="<%= allWorks[i]._id %>"
                            data-title="<%= allWorks[i].title %>"
                            data-artist="<%= allWorks[i].artist || 'Unknown Artist' %>"
                            data-year="<%= allWorks[i].year || '' %>"
                            data-medium="<%= allWorks[i].medium %>"
                            data-style="<%= allWorks[i].style || '' %>"
                            data-dimensions="<%= allWorks[i].dimensions %>"
                            data-price="<%= allWorks[i].price %>"
                            data-img="../<%= allWorks[i].image.replace('A) FrontEnd/', '') %>.jpg"
                        >
                            <img src="../<%= allWorks[i].image.replace('A) FrontEnd/', '') %>.jpg" loading="lazy"/>
                            <div class="gallery-item-eye"><i class="fa-solid fa-eye"></i></div>
                            <div class="gallery-item-info" data-id="<%= allWorks[i]._id %>">
                                <div class="gallery-item-title"><%= allWorks[i].title %></div>
                                <div class="gallery-item-details"><%= allWorks[i].medium %> · <span class="dimensions"><%= allWorks[i].dimensions %></span></div>
                                <div class="gallery-item-price"><%= allWorks[i].price %></div>
                            </div>
                        </div>
                        <% } %>
                    </div>
                </div>

                <div class="empty-state" id="galleryEmpty" style="display:none;">
                    <div class="empty-state-icon"><i class="fa-solid fa-magnifying-glass"></i></div>
                    <h3>No results found</h3>
                    <p>Try a different title, artist name, medium or style.</p>
                </div>
            </div>
        </main>
    </div>

    <script>
        const userInfo = <%- JSON.stringify(userInfo) %>;
        const ALL_WORKS = <%- JSON.stringify(allWorks) %>;
        const CART_IDS = <%- JSON.stringify((userInfo.cartItems).map(id => String(id))) %>;
        const WISH_IDS = <%- JSON.stringify((userInfo.wishList).map(id => String(id))) %>;
        const PURCHASED_IDS = <%- JSON.stringify((userInfo.purchased).map(id => String(id))) %>;
    </script>
    <script src="../Script(JS)/userSpace.js"></script>
</body>
</html>